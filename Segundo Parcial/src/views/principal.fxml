<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="760.0" xmlns="http://javafx.com/javafx/21.0.9" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PrincipalController">
    <children>
        <ListView fx:id="listViewProductos" layoutX="14.0" layoutY="14.0" prefHeight="278.0" prefWidth="731.0" />
        <Button fx:id="btnAgregar" layoutX="22.0" layoutY="310.0" mnemonicParsing="false" onAction="#agregarProducto" prefHeight="39.0" prefWidth="130.0" text="Agregar" />
        <Button fx:id="btnModificar" layoutX="172.0" layoutY="310.0" mnemonicParsing="false" onAction="#modificarProducto" prefHeight="39.0" prefWidth="130.0" text="Modificar" />
        <Button fx:id="btnEliminar" layoutX="322.0" layoutY="310.0" mnemonicParsing="false" onAction="#eliminarProducto" prefHeight="39.0" prefWidth="130.0" text="Eliminar" />
        <Button fx:id="btnExportar" layoutX="472.0" layoutY="310.0" mnemonicParsing="false" onAction="#verArchivoTexto" prefHeight="39.0" prefWidth="130.0" text="Ver Archivo .txt" />
    </children>
</AnchorPane>